        <class name="runners.AccountDetailsTestRunner"/>
    </classes>
</test>

 <test name="5 - Addresses Tests">
    <classes>
        <class name="runners.AddressesTestRunner"/>
    </classes>
</test>

<test name="6 - Product Search Tests">
    <classes>
        <class name="runners.ProductSearchTestRunner"/>
    </classes>
</test>

<test name="7 - Cart Tests">
    <classes>
        <class name="runners.CartTestRunner"/>
    </classes>
</test>

<test name="8 - Checkout Tests">
    <classes>
        <class name="runners.CheckoutTestRunner"/>
    </classes>
</test>

</suite>